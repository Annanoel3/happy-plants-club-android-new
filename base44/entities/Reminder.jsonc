{
  "name": "Reminder",
  "type": "object",
  "rls": {
    "read": true,
    "write": {
      "created_by": "{{user.email}}"
    }
  },
  "properties": {
    "plant_id": {
      "type": "string"
    },
    "plant_name": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "completed": {
      "type": "boolean",
      "default": false
    },
    "is_recurring": {
      "type": "boolean",
      "default": false,
      "description": "Whether this reminder repeats"
    },
    "recurrence_type": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "biweekly",
        "monthly",
        "every_two_hours"
      ],
      "description": "How often the reminder repeats"
    },
    "onesignal_notification_id": {
      "type": "string",
      "description": "OneSignal notification ID for scheduled/recurring notifications"
    },
    "schedule_time": {
      "type": "string",
      "format": "date-time",
      "description": "Specific time for scheduled notification"
    }
  },
  "required": [
    "plant_id",
    "title",
    "due_date"
  ]
}