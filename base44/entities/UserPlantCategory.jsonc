{
  "name": "UserPlantCategory",
  "type": "object",
  "rls": {
    "read": {
      "created_by": "{{user.email}}"
    },
    "write": {
      "created_by": "{{user.email}}"
    }
  },
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the custom plant category"
    },
    "color": {
      "type": "string",
      "description": "Hex color code for the category"
    }
  },
  "required": [
    "name"
  ]
}